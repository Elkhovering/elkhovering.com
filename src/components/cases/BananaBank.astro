  .bb-katana-piece {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 85%;
    max-width: 560px;
    transform: translate(-50%, -50%) rotate(-12deg);
    transition: transform 1s cubic-bezier(0.2, 0.9, 0.3, 1), opacity 0.6s ease;
  }
  /* initial state — разнесены, полупрозрачны */
  .bb-katana-blade {
    transform: translate(-50%, -120%) rotate(-22deg);
    opacity: 0;
  }
  .bb-katana-left {
    transform: translate(-120%, -50%) rotate(-40deg);
    opacity: 0;
  }
  .bb-katana-right {
    transform: translate(20%, -50%) rotate(20deg);
    opacity: 0;
  }
  /* Когда секция в viewport и пройдено достаточно — схлопываются в целое */
  .bb-katana[data-progress="1"] .bb-katana-blade { transform: translate(-50%, -50%) rotate(-12deg); opacity: 1; }
  .bb-katana[data-progress="1"] .bb-katana-left { transform: translate(-50%, -50%) rotate(-12deg); opacity: 1; }
  .bb-katana[data-progress="1"] .bb-katana-right { transform: translate(-50%, -50%) rotate(-12deg); opacity: 1; }

  .bb-katana-labels { position: absolute; inset: 0; pointer-events: none; }
  .bb-katana-label {
    position: absolute;
    font-family: medium;
    font-size: 12px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--bb-accent);
    opacity: 0;
    transition: opacity 0.5s ease;
  }
  .bb-katana[data-progress="1"] .bb-katana-label { opacity: 1; }
  .bb-katana-label-blade { top: 6%; right: 12%; }
  .bb-katana-label-left { bottom: 18%; left: 2%; }
  .bb-katana-label-right { bottom: 8%; right: 4%; }

  /* ─────────── BESTIARY ─────────── */
  .bb-bestiary {
    position: relative;
    padding-top: 10rem;
    padding-bottom: 10rem;
    overflow: hidden;
    background: var(--base);
  }
  .bb-huge {
    font-family: medium;
    font-size: clamp(80px, 16vw, 260px);
    line-height: 0.9;
    margin: 0;
    text-transform: uppercase;
    letter-spacing: -0.02em;
    color: transparent;
    -webkit-text-stroke: 1px var(--text);
    position: relative;
    z-index: 2;
    text-align: center;
    white-space: nowrap;
    transform: translateX(-2%);
  }

  .bb-bestiary-stage {
    position: relative;
    margin-top: -8vw;
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    grid-auto-rows: minmax(240px, 20vw);
    gap: 2rem;
    z-index: 3;
  }
  .bb-beast {
    margin: 0;
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .bb-beast img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    will-change: transform;
  }
  .bb-beast figcaption {
    font-family: roman;
    font-size: 15px;
    line-height: 1.4;
    color: var(--bb-muted);
    max-width: 40ch;
  }
  .bb-beast-bear { grid-column: 1 / span 5; grid-row: span 2; }
  .bb-beast-ox   { grid-column: 7 / span 6; grid-row: 1 / span 1; align-self: start; }
  .bb-beast-monkey { grid-column: 6 / span 5; grid-row: 2 / span 1; align-self: end; }

  /* ─────────── PROCESS ─────────── */
  .bb-process {
    padding-top: 8rem;
    padding-bottom: 8rem;
  }
  .bb-process-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 3rem;
  }
  .bb-process-cell {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    padding-top: 1rem;
    border-top: 1px solid var(--text);
  }
  .bb-process-num {
    font-family: medium;
    font-size: clamp(60px, 6vw, 96px);
    line-height: 1;
    color: var(--text);
  }
  .bb-process-text {
    font-family: roman;
    font-size: 17px;
    line-height: 1.5;
    color: var(--text);
  }
  .bb-process-text strong {
    font-family: medium;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    font-size: 14px;
    display: block;
    margin-bottom: 0.5rem;
    color: var(--bb-accent);
    font-weight: normal;
  }

  /* ─────────── DEPTH ─────────── */
  .bb-depth {
    position: relative;
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: 4rem;
    padding-top: 10rem;
    padding-bottom: 10rem;
    overflow: hidden;
    align-items: center;
  }
  .bb-depth-stage {
    position: relative;
    aspect-ratio: 4 / 3;
    width: 100%;
  }
  .bb-depth-layer {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 90%;
    max-width: 600px;
    transform: translate(-50%, -50%);
    will-change: transform;
  }
  .bb-depth-back { width: 70%; opacity: 0.7; }
  .bb-depth-mid { width: 80%; opacity: 0.85; }
  .bb-depth-front { width: 95%; }

  /* ─────────── OUTCOME ─────────── */
  .bb-outcome {
    padding-top: 10rem;
    padding-bottom: 12rem;
    text-align: center;
    background: var(--base);
  }
  .bb-pull {
    font-family: medium;
    font-size: clamp(44px, 6vw, 112px);
    line-height: 1.05;
    margin: 0 auto;
    max-width: 16ch;
    text-transform: none;
    color: var(--text);
  }
  .bb-cite {
    display: block;
    margin-top: 1.5rem;
    font-family: medium;
    font-size: 14px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--bb-accent);
    font-style: normal;
  }
  .bb-outcome-body {
    margin: 3rem auto 0;
    max-width: 52ch;
    font-family: roman;
    font-size: 18px;
    line-height: 1.55;
    color: var(--text);
    text-align: left;
  }
  .bb-outcome-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.6em;
    margin-top: 4rem;
    font-family: medium;
    font-size: clamp(22px, 2vw, 30px);
    text-transform: uppercase;
    letter-spacing: 0.03em;
    color: var(--text);
    text-decoration: none;
    padding: 0.75rem 0;
    border-bottom: 1px solid var(--bb-accent);
    transition: gap 0.3s ease, color 0.2s ease;
  }
  .bb-outcome-cta:hover { gap: 1.2em; color: var(--bb-accent); }
  .bb-outcome-cta .bb-arrow { transition: transform 0.3s ease; }
  .bb-outcome-cta:hover .bb-arrow { transform: translate(0.3em, -0.3em); }

  /* ─────────── Reveal-анимации ─────────── */
  [data-reveal] {
    opacity: 0;
    transform: translateY(40px);
    transition:
      opacity 0.9s cubic-bezier(0.2, 0.8, 0.3, 1),
      transform 0.9s cubic-bezier(0.2, 0.8, 0.3, 1);
  }
  [data-reveal].is-revealed {
    opacity: 1;
    transform: none;
  }

  /* ─────────── Адаптив ─────────── */
  @media (max-width: 1024px) {
    .bb-section { padding: 6rem 2.5rem; }
    .bb-hero-grid { padding: 6rem 2.5rem 3rem; }
    .bb-back { left: 2.5rem; }
    .bb-brief { grid-template-columns: 1fr; gap: 2rem; padding-top: 6rem; padding-bottom: 6rem; }
    .bb-katana { grid-template-columns: 1fr; min-height: auto; }
    .bb-katana-text { position: static; max-width: none; }
    .bb-katana-stage { position: static; margin: 4rem auto 0; }
    .bb-bestiary-stage { grid-template-columns: 1fr; grid-auto-rows: auto; }
    .bb-beast-bear, .bb-beast-ox, .bb-beast-monkey { grid-column: 1 / -1; grid-row: auto; }
    .bb-beast img { max-height: 60vh; }
    .bb-process-grid { grid-template-columns: 1fr 1fr; gap: 2rem; }
    .bb-depth { grid-template-columns: 1fr; gap: 3rem; }
  }

  @media (max-width: 640px) {
    .bb-section { padding: 4rem 1.25rem; }
    .bb-hero-grid { padding: 5rem 1.25rem 2rem; }
    .bb-back { left: 1.25rem; top: 1.25rem; }
    .bb-hero-meta { flex-direction: column; gap: 0.5rem; }
    .bb-hero-foot { flex-direction: column; align-items: flex-start; gap: 2rem; }
    .bb-title-line-offset { padding-left: 0; }
    .bb-process-grid { grid-template-columns: 1fr; }
    .bb-hero-stage .bb-hero-katana { width: 130vw; }
  }
</style>

<script>
  // Bespoke BananaBank: параллакс, cursor-follow, reveal, katana-прогресс.
  // Работает через делегирование из astro:page-load — переживает навигацию.
  function initBananaBank() {
    const root = document.querySelector('.bb') as HTMLElement | null;
    if (!root) return;

    // ── 1. Reveal on scroll ──
    const reveals = root.querySelectorAll<HTMLElement>('[data-reveal]');
    if (reveals.length) {
      const io = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              const el = entry.target as HTMLElement;
              const delay = parseInt(el.dataset.revealDelay || '0', 10);
              setTimeout(() => el.classList.add('is-revealed'), delay);
              io.unobserve(el);
            }
          });
        },
        { rootMargin: '0px 0px -15% 0px', threshold: 0.1 }
      );
      reveals.forEach((el) => io.observe(el));
    }

    // ── 2. Собираем все движущиеся элементы: parallax + cursor-follow ──
    // Один набор, чтобы пишем transform в одном месте за кадр и не затирали друг друга.
    type MoverEntry = {
      el: HTMLElement;
      base: string;           // исходный inline transform (включая rotate)
      parallax: number;       // speed или 0
      cursor: number;         // strength или 0
      cx: number; cy: number; // сглаженный курсор-оффсет
    };

    const movers: MoverEntry[] = [];
    const seen = new Map<HTMLElement, MoverEntry>();

    const add = (el: HTMLElement): MoverEntry => {
      let m = seen.get(el);
      if (m) return m;
      // Берём computed transform как базу; 'none' → пустая строка, иначе matrix(...)
      const computed = window.getComputedStyle(el).transform;
      const base = computed && computed !== 'none' ? computed : '';
      m = { el, base, parallax: 0, cursor: 0, cx: 0, cy: 0 };
      seen.set(el, m);
      movers.push(m);
      return m;
    };

    root.querySelectorAll<HTMLElement>('[data-parallax]').forEach((el) => {
      const m = add(el);
      m.parallax = parseFloat(el.dataset.parallax || '0');
    });
    root.querySelectorAll<HTMLElement>('[data-cursor-follow]').forEach((el) => {
      const m = add(el);
      m.cursor = parseFloat(el.dataset.cursorFollow || '0');
    });

    // ── 3. Мышь в пределах hero ──
    let mouseX = 0;
    let mouseY = 0;
    const hero = root.querySelector('.bb-hero') as HTMLElement | null;
    const onMove = (e: MouseEvent) => {
      if (!hero) return;
      const rect = hero.getBoundingClientRect();
      mouseX = (e.clientX - rect.left) / rect.width - 0.5;
      mouseY = (e.clientY - rect.top) / rect.height - 0.5;
    };
    const onLeave = () => { mouseX = 0; mouseY = 0; };
    if (hero) {
      hero.addEventListener('mousemove', onMove);
      hero.addEventListener('mouseleave', onLeave);
    }

    // ── 4. Katana progress ──
    const katanaSection = root.querySelector('[data-katana-section]') as HTMLElement | null;

    // ── RAF ──
    let rafId = 0;
    const tick = () => {
      const vh = window.innerHeight;

      movers.forEach((m) => {
        let ty = 0;
        if (m.parallax) {
          const rect = m.el.getBoundingClientRect();
          const centerY = rect.top + rect.height / 2;
          const dist = centerY - vh / 2;
          ty = (dist / vh) * m.parallax;
        }
        if (m.cursor) {
          const tx = mouseX * m.cursor;
          const tyC = mouseY * m.cursor;
          m.cx += (tx - m.cx) * 0.08;
          m.cy += (tyC - m.cy) * 0.08;
        }
        // Сборка: computed-matrix сначала (включает rotate из CSS), потом наши смещения.
        // translate/translateY добавляется после matrix — браузер применит последовательно.
        const dx = m.cursor ? m.cx : 0;
        const dy = ty + (m.cursor ? m.cy : 0);
        m.el.style.transform = `${m.base} translate(${dx}px, ${dy}px)`;
      });

      if (katanaSection) {
        const r = katanaSection.getBoundingClientRect();
        const total = r.height - vh;
        const traveled = -r.top;
        const progress = total > 0 ? Math.max(0, Math.min(1, traveled / (total * 0.4))) : 0;
        katanaSection.dataset.progress = progress > 0.5 ? '1' : '0';
      }

      rafId = requestAnimationFrame(tick);
    };
    rafId = requestAnimationFrame(tick);

    document.addEventListener(
      'astro:before-preparation',
      () => {
        cancelAnimationFrame(rafId);
        if (hero) {
          hero.removeEventListener('mousemove', onMove);
          hero.removeEventListener('mouseleave', onLeave);
        }
      },
      { once: true }
    );
  }

  document.addEventListener('astro:page-load', initBananaBank);
</script>
