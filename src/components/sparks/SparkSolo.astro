---
// Один изолированный визуал (объект кейса) с подписью-подложкой.
// Пример: <SparkSolo src="/…/Bear.png" caption="Медведь — образ медвежьего рынка." />
interface Props {
  src: string;
  caption?: string;
  background?: string; // hex или CSS-цвет для фона. По умолчанию тёмно-фиолетовый.
  aspect?: string;     // CSS aspect-ratio, по умолчанию "4 / 3"
}
const { src, caption, background = '#1a0b2e', aspect = '4 / 3' } = Astro.props;
---
<figure class="spark-solo" style={`--spark-bg: ${background}; --spark-aspect: ${aspect};`}>
  <div class="spark-solo-frame">
    <img src={src} alt={caption || ''} loading="lazy" />
  </div>
  {caption && <figcaption>{caption}</figcaption>}
</figure>

<style>
  .spark-solo {
    margin: 3rem 0;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .spark-solo-frame {
    position: relative;
    width: 100%;
    aspect-ratio: var(--spark-aspect);
    background: var(--spark-bg);
    border-radius: 2px;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .spark-solo-frame img {
    max-width: 75%;
    max-height: 80%;
    object-fit: contain;
    display: block;
    filter: drop-shadow(0 20px 60px rgba(0, 0, 0, 0.45));
    transition: transform 0.8s ease;
  }
  .spark-solo:hover .spark-solo-frame img { transform: scale(1.03); }
  .spark-solo figcaption {
    font-family: roman;
    font-size: 15px;
    line-height: 1.4;
    opacity: 0.7;
    max-width: 48ch;
    margin: 0;
  }
</style>
