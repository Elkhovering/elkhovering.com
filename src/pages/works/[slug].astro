---
import { getCollection, getEntry } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import CaseStudy from '../../components/CaseStudy.astro';
import BananaBank from '../../components/cases/BananaBank.astro';

// Карта bespoke-страниц. Для slug из карты рендерим кастомный компонент,
// остальное идёт через дефолтный CaseStudy.
const customCases: Record<string, any> = {
  'banana-bank': BananaBank,
};

export async function getStaticPaths() {
  // Канон slug-ов — EN-коллекция. RU-файл обязателен (иначе build-time ошибка ниже).
  const enEntries = await getCollection('works', ({ id, data }: any) =>
    id.startsWith('en/') && !data.draft,
  );
  return enEntries.map((entry: any) => ({
    params: { slug: entry.data.slug },
    props: { slug: entry.data.slug },
  }));
}

const { slug } = Astro.props;
const entryEn = await getEntry('works', `en/${slug}`);
const entryRu = await getEntry('works', `ru/${slug}`);

if (!entryEn || !entryRu) {
  throw new Error(`Missing locale entry for slug "${slug}" (en: ${!!entryEn}, ru: ${!!entryRu})`);
}

const CaseComponent = customCases[slug] ?? CaseStudy;
---
<Layout
  title={`${entryEn.data.title} — Elkhovering`}
  description={entryEn.data.summary}
>
  <CaseComponent entryEn={entryEn} entryRu={entryRu} />
</Layout>
